<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>California Extreme 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Orbitron:wght@400;700;900&family=VT323&display=swap" rel="stylesheet">
<style>
  :root {
    --neon-pink: #ff006e;
    --neon-cyan: #00f5ff;
    --neon-yellow: #ffe600;
    --neon-green: #39ff14;
    --neon-purple: #bf00ff;
    --dark-bg: #04010f;
    --grid-color: rgba(0, 245, 255, 0.08);
  }

- { margin: 0; padding: 0; box-sizing: border-box; }

body {
background: var(–dark-bg);
font-family: ‘Press Start 2P’, monospace;
color: white;
min-height: 100vh;
overflow-x: hidden;
}

/* Scanline overlay */
body::before {
content: ‘’;
position: fixed;
top: 0; left: 0; right: 0; bottom: 0;
background: repeating-linear-gradient(
0deg,
transparent,
transparent 2px,
rgba(0,0,0,0.15) 2px,
rgba(0,0,0,0.15) 4px
);
pointer-events: none;
z-index: 100;
}

/* Perspective grid background */
.grid-bg {
position: fixed;
top: 0; left: 0; right: 0; bottom: 0;
background:
linear-gradient(var(–grid-color) 1px, transparent 1px),
linear-gradient(90deg, var(–grid-color) 1px, transparent 1px);
background-size: 40px 40px;
z-index: 0;
}

.grid-bg::after {
content: ‘’;
position: absolute;
bottom: 0; left: 0; right: 0;
height: 50%;
background: linear-gradient(to top, var(–dark-bg), transparent);
}

.container {
position: relative;
z-index: 1;
max-width: 900px;
margin: 0 auto;
padding: 30px 20px 60px;
}

/* Header */
.header {
text-align: center;
margin-bottom: 10px;
padding: 30px 0 20px;
}

.insert-coin {
font-family: ‘VT323’, monospace;
font-size: 22px;
color: var(–neon-yellow);
letter-spacing: 4px;
animation: blink 1s step-end infinite;
margin-bottom: 10px;
}

@keyframes blink { 50% { opacity: 0; } }

.title-line1 {
font-family: ‘Orbitron’, sans-serif;
font-weight: 900;
font-size: clamp(28px, 6vw, 58px);
color: var(–neon-cyan);
text-shadow:
0 0 10px var(–neon-cyan),
0 0 30px var(–neon-cyan),
0 0 60px var(–neon-cyan);
letter-spacing: 4px;
animation: flicker 4s infinite;
}

.title-line2 {
font-family: ‘Orbitron’, sans-serif;
font-weight: 900;
font-size: clamp(42px, 10vw, 92px);
color: var(–neon-pink);
text-shadow:
0 0 10px var(–neon-pink),
0 0 30px var(–neon-pink),
0 0 80px var(–neon-pink);
line-height: 1;
letter-spacing: 6px;
}

@keyframes flicker {
0%,19%,21%,23%,25%,54%,56%,100% { opacity: 1; }
20%,24%,55% { opacity: 0.4; }
}

.year-badge {
display: inline-block;
font-family: ‘Orbitron’, sans-serif;
font-size: clamp(16px, 3vw, 28px);
font-weight: 700;
color: var(–neon-yellow);
border: 2px solid var(–neon-yellow);
padding: 4px 20px;
margin-top: 8px;
text-shadow: 0 0 10px var(–neon-yellow);
box-shadow: 0 0 15px var(–neon-yellow), inset 0 0 10px rgba(255,230,0,0.1);
}

/* Date banner */
.date-banner {
background: linear-gradient(135deg, rgba(255,0,110,0.2), rgba(0,245,255,0.2));
border: 2px solid var(–neon-cyan);
border-left: 6px solid var(–neon-pink);
text-align: center;
padding: 18px;
margin: 24px 0;
position: relative;
box-shadow: 0 0 30px rgba(0,245,255,0.2), inset 0 0 20px rgba(0,0,0,0.5);
}

.date-banner::before, .date-banner::after {
content: ‘★’;
position: absolute;
top: 50%;
transform: translateY(-50%);
color: var(–neon-yellow);
font-size: 20px;
text-shadow: 0 0 10px var(–neon-yellow);
}
.date-banner::before { left: 16px; }
.date-banner::after { right: 16px; }

.date-text {
font-family: ‘Orbitron’, sans-serif;
font-size: clamp(14px, 3.5vw, 26px);
font-weight: 900;
color: white;
letter-spacing: 3px;
}

.date-text span {
color: var(–neon-yellow);
text-shadow: 0 0 10px var(–neon-yellow);
}

.location-text {
font-family: ‘VT323’, monospace;
font-size: 20px;
color: var(–neon-green);
letter-spacing: 2px;
margin-top: 6px;
}

/* Section headers */
.section-header {
font-family: ‘VT323’, monospace;
font-size: 28px;
letter-spacing: 4px;
padding: 8px 16px;
margin: 24px 0 12px;
position: relative;
}

.section-header.cyan {
color: var(–neon-cyan);
border-bottom: 2px solid var(–neon-cyan);
text-shadow: 0 0 15px var(–neon-cyan);
}
.section-header.pink {
color: var(–neon-pink);
border-bottom: 2px solid var(–neon-pink);
text-shadow: 0 0 15px var(–neon-pink);
}
.section-header.yellow {
color: var(–neon-yellow);
border-bottom: 2px solid var(–neon-yellow);
text-shadow: 0 0 15px var(–neon-yellow);
}
.section-header.green {
color: var(–neon-green);
border-bottom: 2px solid var(–neon-green);
text-shadow: 0 0 15px var(–neon-green);
}
.section-header.purple {
color: var(–neon-purple);
border-bottom: 2px solid var(–neon-purple);
text-shadow: 0 0 15px var(–neon-purple);
}

.section-header .pixel-icon {
margin-right: 10px;
}

/* Speaker grid */
.speaker-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 10px;
margin-bottom: 16px;
}

@media (max-width: 600px) {
.speaker-grid { grid-template-columns: 1fr; }
}

.talk-card {
background: rgba(0,0,0,0.6);
border: 1px solid rgba(0,245,255,0.3);
padding: 12px;
position: relative;
transition: border-color 0.2s;
}

.talk-card:hover {
border-color: var(–neon-cyan);
box-shadow: 0 0 15px rgba(0,245,255,0.3);
}

.talk-time {
font-family: ‘VT323’, monospace;
font-size: 18px;
color: var(–neon-yellow);
margin-bottom: 4px;
}

.talk-title {
font-family: ‘VT323’, monospace;
font-size: 16px;
color: white;
line-height: 1.4;
margin-bottom: 6px;
}

.talk-speaker {
font-family: ‘VT323’, monospace;
font-size: 14px;
color: rgba(0,245,255,0.7);
}

/* Music lineup */
.music-list {
display: flex;
flex-direction: column;
gap: 8px;
}

.music-item {
display: flex;
align-items: center;
gap: 16px;
background: rgba(255,0,110,0.08);
border: 1px solid rgba(255,0,110,0.3);
padding: 10px 14px;
}

.music-time {
font-family: ‘VT323’, monospace;
font-size: 20px;
color: var(–neon-pink);
min-width: 75px;
}

.music-name {
font-family: ‘VT323’, monospace;
font-size: 18px;
color: white;
}

.music-genre {
font-family: ‘VT323’, monospace;
font-size: 14px;
color: rgba(255,255,255,0.5);
margin-left: auto;
}

/* Tournaments */
.tournament-grid {
display: grid;
grid-template-columns: repeat(3, 1fr);
gap: 10px;
}

@media (max-width: 600px) {
.tournament-grid { grid-template-columns: 1fr; }
}

.tournament-card {
background: rgba(0,0,0,0.6);
border: 2px solid var(–neon-purple);
padding: 14px 10px;
text-align: center;
box-shadow: 0 0 12px rgba(191,0,255,0.2);
}

.tournament-icon {
font-size: 28px;
margin-bottom: 6px;
display: block;
}

.tournament-name {
font-family: ‘VT323’, monospace;
font-size: 18px;
color: var(–neon-purple);
display: block;
margin-bottom: 4px;
}

.tournament-detail {
font-family: ‘VT323’, monospace;
font-size: 13px;
color: rgba(255,255,255,0.6);
line-height: 1.5;
}

/* Info boxes */
.info-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 12px;
margin-top: 8px;
}

@media (max-width: 600px) {
.info-grid { grid-template-columns: 1fr; }
}

.info-box {
background: rgba(0,0,0,0.5);
border: 1px solid rgba(57,255,20,0.4);
padding: 14px;
}

.info-box-title {
font-family: ‘VT323’, monospace;
font-size: 20px;
color: var(–neon-green);
margin-bottom: 8px;
border-bottom: 1px solid rgba(57,255,20,0.3);
padding-bottom: 4px;
}

.info-box p {
font-family: ‘VT323’, monospace;
font-size: 15px;
color: rgba(255,255,255,0.75);
line-height: 1.7;
}

.info-box a {
color: var(–neon-cyan);
text-decoration: none;
}

/* Warning box */
.warning-box {
background: rgba(255,230,0,0.07);
border: 2px solid var(–neon-yellow);
padding: 14px 18px;
margin: 20px 0;
display: flex;
align-items: flex-start;
gap: 14px;
box-shadow: 0 0 20px rgba(255,230,0,0.1);
}

.warning-icon {
font-size: 28px;
flex-shrink: 0;
}

.warning-text {
font-family: ‘VT323’, monospace;
font-size: 16px;
color: var(–neon-yellow);
line-height: 1.7;
}

/* Footer */
.footer {
text-align: center;
margin-top: 40px;
padding-top: 20px;
border-top: 2px solid rgba(0,245,255,0.3);
}

.footer-url {
font-family: ‘VT323’, monospace;
font-size: 22px;
color: var(–neon-cyan);
text-shadow: 0 0 10px var(–neon-cyan);
letter-spacing: 3px;
text-decoration: none;
}

.footer-credit {
font-family: ‘VT323’, monospace;
font-size: 16px;
color: rgba(255,255,255,0.3);
margin-top: 10px;
animation: blink 2s step-end infinite;
}

/* Pixel divider */
.pixel-divider {
text-align: center;
font-family: ‘VT323’, monospace;
font-size: 20px;
color: rgba(255,255,255,0.15);
letter-spacing: 3px;
margin: 6px 0;
}

.highlight {
color: var(–neon-yellow);
text-shadow: 0 0 8px var(–neon-yellow);
}

.tag {
display: inline-block;
font-family: ‘VT323’, monospace;
font-size: 13px;
background: rgba(0,245,255,0.15);
color: var(–neon-cyan);
border: 1px solid var(–neon-cyan);
padding: 1px 8px;
margin-left: 6px;
}
</style>

</head>
